# single.jogga.fit — jogga (core) instance
# Copy to .env.single and fill in real values. Never commit .env.single.

JOGGA__SERVER__HOST=0.0.0.0
JOGGA__SERVER__PORT=80

JOGGA__DATABASE__URL=postgres://jogga:jogga@postgres:5432/jogga
JOGGA__DATABASE__MAX_CONNECTIONS=5

JOGGA__INSTANCE__DOMAIN=single.jogga.fit
JOGGA__INSTANCE__NAME=Jogga
JOGGA__INSTANCE__DESCRIPTION=Personal fitness tracker

# Username for the single owner account (created on first boot via seed-owner)
JOGGA__OWNER__USERNAME=owner
# Email or E.164 phone for OTP delivery (password reset)
JOGGA__OWNER__CONTACT=you@example.com

# SMTP — required for password reset emails
JOGGA__EMAIL__SMTP_HOST=smtp.example.com
JOGGA__EMAIL__SMTP_PORT=587
JOGGA__EMAIL__SMTP_USERNAME=user@example.com
JOGGA__EMAIL__SMTP_PASSWORD=changeme
JOGGA__EMAIL__FROM_ADDRESS=noreply@single.jogga.fit

RUST_LOG=info
