  "query": "SELECT a.ap_id, a.username, a.domain,\n                      a.is_local AS \"is_local: bool\",\n                      a.display_name, a.avatar_url,\n                      f.accepted AS \"accepted: bool\"\n               FROM following f\n               JOIN actors a ON a.id = f.target_id\n               WHERE f.actor_id = ?\n               ORDER BY f.created_at DESC\n               LIMIT ?",
